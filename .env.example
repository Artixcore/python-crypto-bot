# Copy to .env and fill. Never commit .env.



# Mode: dev | paper | live

CRYPTO_BOT_PROFILE=dev



# Binance API (Spot trading only; disable withdrawals on the key)

CRYPTO_BOT_BINANCE_API_KEY=

CRYPTO_BOT_BINANCE_API_SECRET=



# LIVE requires explicit confirmation (set to "yes" only when deploying live)

CRYPTO_BOT_LIVE_CONFIRM=no



# Strategy / sizing (MA+RSI runner and backtests)

CRYPTO_BOT_POSITION_SIZE_PCT_OF_EQUITY=2.0

CRYPTO_BOT_MA_FAST_PERIOD=12

CRYPTO_BOT_MA_SLOW_PERIOD=26

CRYPTO_BOT_RSI_PERIOD=14

CRYPTO_BOT_RSI_BUY_MAX=45.0

CRYPTO_BOT_RSI_EXIT_MIN=70.0



# Optional ML filter (off unless enabled)

CRYPTO_BOT_ML_ENABLED=no

CRYPTO_BOT_ML_MODEL_PATH=

CRYPTO_BOT_ML_SHADOW=no



# Telegram (long polling; keys stay server-side only)

CRYPTO_BOT_TELEGRAM_BOT_TOKEN=

CRYPTO_BOT_TELEGRAM_ALLOWED_USER_IDS=

CRYPTO_BOT_TELEGRAM_TRADING_ENABLED=no

CRYPTO_BOT_SNAPSHOT_SYMBOLS=BTC/USDT,SOL/USDT


