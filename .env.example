# Copy to .env and fill. Never commit .env.

# Mode: dev | paper | live
CRYPTO_BOT_PROFILE=dev

# Binance API (Spot trading only; disable withdrawals on the key)
CRYPTO_BOT_BINANCE_API_KEY=
CRYPTO_BOT_BINANCE_API_SECRET=

# LIVE requires explicit confirmation (set to "yes" only when deploying live)
CRYPTO_BOT_LIVE_CONFIRM=no

# Optional: path to ML filter artifact for gated use
CRYPTO_BOT_ML_MODEL_PATH=
# Log ML scores without blocking trades (yes/no)
CRYPTO_BOT_ML_SHADOW=no

# Local HTML dashboard (http://127.0.0.1:8765) — keys stay server-side only
CRYPTO_BOT_DASHBOARD_HOST=127.0.0.1
CRYPTO_BOT_DASHBOARD_PORT=8765
CRYPTO_BOT_DASHBOARD_SYMBOLS=BTC/USDT,ETH/USDT
CRYPTO_BOT_DASHBOARD_REFRESH_SEC=8
